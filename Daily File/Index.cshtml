@model _22JULY_001_2026.Models.Stationary


<div class="text-center">
    <h1 class="display-4">Welcome</h1>
</div>
<form asp-controller="Home" asp-action="Index" method="post">

    <div>
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" style="colour : red"></span>
    </div>
    <br />

    <div>
        <label asp-for="Price"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" style="colour : red"></span>
    </div>
    <br />

    <div>
        <label asp-for="Category"></label>
        <input asp-for="Category" class="form-control" />
        <span asp-validation-for="Category" style="colour : red"></span>
    </div>
    <br />

    <div>
        <label asp-for="Stock"></label>
        <input asp-for="Stock" class="form-control" />
        <span asp-validation-for="Stock" style="colour : red"></span>
    </div>
    <br />

    <button type="submit"> Save Product</button>

</form>

<div asp-validation-summary="All"></div>